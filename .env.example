# SharePoint設定（改修(SP連携マージ): jphgt109536/TestListを正式接続先として更新）
SITE_URL=https://globalhonda.sharepoint.com/sites/jphgt109536
SP_LIST_PATH=/sites/jphgt109536/Lists/TestList

# プロキシ設定（社内ネットワーク）
PROXY_URL=http://hg-vm-prx-sdc.t.rd.honda.com:8080

# サーバーポート（デフォルト3000）
PORT=3000

# 改修(常駐化対応): sp_client.jsがPythonを子プロセスで呼び出す際の実行ファイル絶対パス。
# 未設定時は 'python' コマンドをPATH解決に任せるが、タスクスケジューラのバッチログオン環境では
# Windowsのアプリ実行エイリアス（WindowsApps\python.exe スタブ）が誤って解決され、
# 無出力のまま即終了する事象があるため、絶対パスを明示すること。
# 改修(全ユーザー共通化): 担当者交代時にも有効な値を保つため、特定ユーザーのプロファイル配下
# （C:\Users\<ユーザー名>\...）ではなく、全ユーザー共通の場所へPythonをインストールしその絶対パスを指定する。
# 例: PYTHON_EXE=C:\Program Files\Python312\python.exe

# 改修(CSV集約): CSVファイルが増えクラッタ化したため、全CSVを CSVデータ\ フォルダへ集約した
# 本番環境（RC25020358）では絶対パスに変更すること

# 改修(筐体マスタ共通化): 筐体マスタCSV（west/southルーム別）を格納するディレクトリ
# 例: MACHINE_CSV_DIR=C:\work\funao\統合HILS予約サイト\CSVデータ\筐体マスタ
MACHINE_CSV_DIR=C:\work\funao\統合HILS予約サイト\CSVデータ\筐体マスタ

# 改修(凡例共通化): 凡例マスタCSV（全ルーム共通・単一ファイル）のパス
# 例: LEGEND_MASTER_PATH=C:\work\funao\統合HILS予約サイト\CSVデータ\凡例マスタ.csv
LEGEND_MASTER_PATH=C:\work\funao\統合HILS予約サイト\CSVデータ\凡例マスタ.csv

# 改修(休日設定): 休日リストCSV（全ルーム共通・単一ファイル）のパス
# 例: HOLIDAY_CSV_PATH=C:\work\funao\統合HILS予約サイト\CSVデータ\休日リスト.csv
HOLIDAY_CSV_PATH=C:\work\funao\統合HILS予約サイト\CSVデータ\休日リスト.csv

# 改修(マニュアルHTTP配信): マニュアルPDF配信元ディレクトリ（未設定時は既定パス ../マニュアル）
# 本番環境（Webアプリ階層が無くbackendの一つ上が直接マニュアル\）では未設定のままでよい
# 例: MANUAL_DIR=C:\work\funao\統合HILS予約サイト\マニュアル

# メール送信元アドレス（担当者交代時はここを新担当者のアドレスに変更する）
MAIL_FROM=xxxx@jp.honda
